<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
  <category label="Dominio">
    <setting id="telegram_channel" type="text" label="Canal de Telegram (sin @)" default="DonTorrent"/>
    <setting id="manual_domain" type="text" label="Dominio manual (vacio = automatico)" default=""/>
    <setting id="cache_hours" type="slider" label="Revalidar dominio cada (horas)" default="12" range="1,1,72" option="int"/>
    <setting id="cached_domain" type="text" label="Dominio en cache" default="" visible="false"/>
    <setting id="cached_at" type="text" label="" default="0" visible="false"/>
  </category>
  <category label="TMDB">
    <setting id="tmdb_enabled" type="bool" label="Enriquecer con TMDB (caratulas/sinopsis)" default="true"/>
    <setting id="tmdb_api_key" type="text" label="TMDB API key (opcional)" default=""/>
    <setting id="tmdb_lang" type="text" label="Idioma TMDB" default="es-ES"/>
  </category>
  <category label="Reproduccion">
    <setting id="player_backend" type="enum" label="Modo de reproduccion preferido"
             values="Auto (Real-Debrid si esta configurado, si no Elementum)|Solo Real-Debrid|Solo Elementum"
             default="0"/>
    <setting id="skip_rar_warning" type="bool" label="No avisar si el torrent es RAR (Elementum)" default="false"/>
  </category>
  <category label="Real-Debrid">
    <setting id="rd_enabled" type="bool" label="Activar Real-Debrid" default="false"/>
    <setting id="rd_token" type="text" label="API token (real-debrid.com -> Mi cuenta -> API)" default="" option="hidden"/>
    <setting id="rd_test" type="action" label="Probar conexion" action="RunPlugin(plugin://plugin.video.dontorrent/?action=rd_test)"/>
  </category>
</settings>
