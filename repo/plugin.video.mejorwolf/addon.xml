<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.mejorwolf" name="MejorWolf" version="2.4.0" provider-name="israel">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" version="2.22.0"/>
    <import addon="script.module.beautifulsoup4" version="4.6.2"/>
    <import addon="plugin.video.elementum" version="0.0.1" optional="true"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es_ES">Torrents en castellano para Kodi</summary>
    <description lang="es_ES">Addon privado v2.4.0. 3 fuentes: DonTorrent (30K+ pelis, 14K+ series, documentales) + EliteTorrent + WolfMax4K. Todo en castellano. Portadas TMDB. Busqueda inteligente multi-fuente. Documentales. Anti-bloqueo ISP via DoH + proxy Cloudflare Worker. Resolucion automatica Anubis PoW. Reproduccion con Elementum.</description>
    <platform>all</platform>
    <language>es</language>
    <license>Private</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon>
