<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.elementum.spanish" name="Elementum - Espanol" version="0.1.0" provider-name="DonTorrent">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" version="2.22.0"/>
    <import addon="script.module.beautifulsoup4" version="4.9.3"/>
    <import addon="plugin.video.elementum"/>
    <import addon="plugin.video.dontorrent" optional="true"/>
  </requires>
  <extension point="xbmc.python.script" library="addon.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es_ES">Proveedor de torrents en castellano para Elementum</summary>
    <description lang="es_ES">Anade fuentes en espanol castellano (DonTorrent, MejorTorrent, WolfMax4k, DivxTotal) como proveedor nativo de Elementum. Resuelve dominios automaticamente desde Telegram.</description>
    <platform>all</platform>
    <language>es</language>
    <license>Private</license>
    <reuselanguageinvoker>true</reuselanguageinvoker>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon>
