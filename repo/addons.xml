  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es_ES">Repositorio MejorWolf para Kodi (auto-actualizacion)</summary>
    <description lang="es_ES">Repositorio privado que entrega actualizaciones automaticas de MejorWolf, DonTorrent y Elementum - Espanol.</description>
    <platform>all</platform>
    <license>Private</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon></addons>