<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons><addon id="plugin.video.dontorrent" name="DonTorrent" version="0.5.1" provider-name="DonTorrent">
  <requires>
    <import addon="xbmc.python" version="3.0.0" />
    <import addon="script.module.requests" version="2.22.0" />
    <import addon="script.module.beautifulsoup4" version="4.9.3" />
    <import addon="plugin.video.elementum" optional="true" />
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es_ES">Navegador privado de DonTorrent para Kodi</summary>
    <description lang="es_ES">Addon privado para navegar DonTorrent y reproducir mediante Elementum. Resuelve automaticamente el dominio activo consultando el canal publico de Telegram.</description>
    <platform>all</platform>
    <language>es</language>
    <license>Private</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon><addon id="plugin.video.mejorwolf" name="MejorWolf" version="2.9.15" provider-name="israel">
  <requires>
    <import addon="xbmc.python" version="3.0.0" />
    <import addon="script.module.requests" version="2.22.0" />
    <import addon="script.module.beautifulsoup4" version="4.6.2" />
    <import addon="plugin.video.elementum" version="0.0.1" optional="true" />
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.service" library="service.py" />
  <extension point="xbmc.addon.metadata">
    <summary lang="es_ES">Torrents en castellano para Kodi</summary>
    <description lang="es_ES">Addon privado v2.4.2. 3 fuentes: DonTorrent + EliteTorrent + WolfMax4K. Todo en castellano. Busqueda con jerarquia clara (carpeta por fuente, series agrupadas dentro). Portadas TMDB. Anti-bloqueo via Render relay (Anubis PoW server-side). Reproduccion con Elementum.</description>
    <platform>all</platform>
    <language>es</language>
    <license>Private</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon><addon id="script.elementum.spanish" name="Elementum - Espanol" version="0.1.0" provider-name="DonTorrent">
  <requires>
    <import addon="xbmc.python" version="3.0.0" />
    <import addon="script.module.requests" version="2.22.0" />
    <import addon="script.module.beautifulsoup4" version="4.9.3" />
    <import addon="plugin.video.elementum" />
    <import addon="plugin.video.dontorrent" optional="true" />
  </requires>
  <extension point="xbmc.python.script" library="addon.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es_ES">Proveedor de torrents en castellano para Elementum</summary>
    <description lang="es_ES">Anade fuentes en espanol castellano (DonTorrent, MejorTorrent, WolfMax4k, DivxTotal) como proveedor nativo de Elementum. Resuelve dominios automaticamente desde Telegram.</description>
    <platform>all</platform>
    <language>es</language>
    <license>Private</license>
    <reuselanguageinvoker>true</reuselanguageinvoker>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon><addon id="repository.mejorwolf" name="MejorWolf Repo" version="1.4.0" provider-name="israel">
  <extension point="xbmc.addon.repository" name="MejorWolf Repo">
    <dir>
      <info compressed="false">https://raw.githubusercontent.com/tictacfit01-source/dontorrent-kodi/main/repo/addons.xml</info>
