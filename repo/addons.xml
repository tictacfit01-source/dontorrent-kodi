<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons><addon id="plugin.video.dontorrent" name="DonTorrent" version="0.5.1" provider-name="DonTorrent">
  <requires>
    <import addon="xbmc.python" version="3.0.0" />
    <import addon="script.module.requests" version="2.22.0" />
    <import addon="script.module.beautifulsoup4" version="4.9.3" />
    <import addon="plugin.video.elementum" optional="true" />
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es_ES">Navegador privado de DonTorrent para Kodi</summary>
    <description lang="es_ES">Addon privado para navegar DonTorrent y reproducir mediante Elementum. Resuelve automaticamente el dominio activo consultando el canal publico de Telegram.</description>
    <platform>all</platform>
    <language>es</language>
    <license>Private</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon><addon id="repository.dontorrent" name="DonTorrent Repo" version="1.0.1" provider-name="DonTorrent">
  <extension point="xbmc.addon.repository" name="DonTorrent Repo">
    <info compressed="false">https://raw.githubusercontent.com/tictacfit01-source/dontorrent-kodi/main/repo/addons.xml</info>
    <checksum>https://raw.githubusercontent.com/tictacfit01-source/dontorrent-kodi/main/repo/addons.xml.md5</checksum>
    <datadir zip="true">https://raw.githubusercontent.com/tictacfit01-source/dontorrent-kodi/main/repo/</datadir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es_ES">Repositorio privado para el addon DonTorrent</summary>
    <description lang="es_ES">Repositorio que entrega actualizaciones automaticas del addon DonTorrent.</description>
    <platform>all</platform>
    <license>Private</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon></addons>